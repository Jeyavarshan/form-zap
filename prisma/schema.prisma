generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FormIntegration {
  id                      String           @id @default(uuid())
  workspaceId             String
  workspacePublicId       String
  formId                  String
  formVersionId           String
  formName                String
  provider                String
  flowId                  String?
  flowJson                Json?
  screenCount             Int              @default(1)
  webhookUrl              String
  ylyncWebhookUrl         String
  publishStatus           String           @default("draft")
  connectionStatus        String           @default("not_configured")
  lastResponseAt          DateTime?
  createdInFormZap        Boolean          @default(true)
  customerDatabaseChanged Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  flowEvents              FlowEvent[]
  submissions             FlowSubmission[]

  @@unique([workspaceId, formId])
  @@unique([workspacePublicId, provider, flowId])
  @@index([workspacePublicId, provider])
  @@index([workspacePublicId, flowId])
}

model FlowSend {
  id                String   @id @default(uuid())
  flowToken         String   @unique
  workspaceId       String
  workspacePublicId String
  formId            String
  formName          String
  provider          String
  flowId            String
  recipientPhone    String
  ylyncWebhookUrl   String
  status            String   @default("poc_send_created")
  createdAt         DateTime @default(now())

  @@index([workspaceId, formId])
  @@index([workspacePublicId, provider, flowId])
}

model WebhookEvent {
  id                String      @id @default(uuid())
  workspacePublicId String
  provider          String
  receivedAt        DateTime    @default(now())
  processingStatus  String      @default("received")
  rawPayload        Json
  eventCount        Int         @default(0)
  mappedCount       Int         @default(0)
  unmappedCount     Int         @default(0)
  errorMessage      String?
  flowEvents        FlowEvent[]

  @@index([workspacePublicId, processingStatus, receivedAt])
  @@index([provider, receivedAt])
}

model FlowEvent {
  id                String           @id @default(uuid())
  type              String
  provider          String
  workspacePublicId String
  rawEventId        String
  rawEvent          WebhookEvent     @relation(fields: [rawEventId], references: [id], onDelete: Cascade)
  messageId         String?
  flowId            String?
  flowToken         String?
  contactPhone      String?
  contactName       String?
  answers           Json
  occurredAt        DateTime
  formIntegrationId String?
  formIntegration   FormIntegration? @relation(fields: [formIntegrationId], references: [id], onDelete: SetNull)
  formId            String?
  mapped            Boolean          @default(false)
  createdAt         DateTime         @default(now())
  submission        FlowSubmission?

  @@index([workspacePublicId, type, occurredAt])
  @@index([formIntegrationId, occurredAt])
  @@index([flowToken])
  @@index([flowId])
}

model FlowSubmission {
  id                String          @id @default(uuid())
  idempotencyKey    String          @unique
  flowEventId       String          @unique
  flowEvent         FlowEvent       @relation(fields: [flowEventId], references: [id], onDelete: Cascade)
  formIntegrationId String
  formIntegration   FormIntegration @relation(fields: [formIntegrationId], references: [id], onDelete: Cascade)
  workspaceId       String
  workspacePublicId String
  formId            String
  formName          String
  provider          String
  flowId            String?
  flowToken         String?
  contactPhone      String?
  contactName       String?
  answers           Json
  submittedAt       DateTime
  createdAt         DateTime        @default(now())

  @@index([workspaceId, formId, submittedAt])
  @@index([workspacePublicId, provider, submittedAt])
}

model Workspace {
  id               String   @id @default(uuid())
  name             String   @default("My Workspace")
  publicId         String   @unique
  planName         String   @default("Free")
  responsesCount   Int      @default(0)
  flowsCount       Int      @default(0)
  aiCreditsCount   Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions    Subscription[]
  payments         PaymentTransaction[]
  googleCredential WorkspaceGoogleCredential?
  walletTransactions WalletTransaction[]
}


model Plan {
  id           String   @id @default(uuid())
  name         String   @unique
  amount       Float
  currency     String   @default("INR")
  interval     String   @default("MONTHLY")
  maxFlows     Int      @default(3)
  maxResponses Int      @default(200)
  aiCredits    Int      @default(3)
  maxApiKeys   Int      @default(0)
  hasGoogleSheets Boolean @default(false)
  hasAdvancedFlow Boolean @default(false)
  hasWhiteLabel   Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  subscriptions Subscription[]
}

model Subscription {
  id                 String   @id @default(uuid())
  workspaceId        String
  planId             String
  status             String   @default("INACTIVE")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan               Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments           PaymentTransaction[]
}

model PaymentTransaction {
  id                String   @id @default(uuid())
  workspaceId       String
  subscriptionId    String?
  amount            Float
  currency          String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  razorpaySignature String?
  status            String   @default("PENDING")
  errorReason       String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
}

model WorkspaceGoogleCredential {
  id                String   @id @default(uuid())
  workspaceId       String   @unique
  workspacePublicId String   @unique
  accessToken       String
  refreshToken      String
  expiryDate        BigInt?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model GoogleSheetConnection {
  id                String   @id @default(uuid())
  workspacePublicId String
  formId            String
  formName          String
  numberId          String
  numberLabel       String
  spreadsheetId     String
  spreadsheetUrl    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([workspacePublicId, formId])
  @@unique([workspacePublicId, formId, numberId])
}

model WalletTransaction {
  id              String   @id @default(uuid())
  workspaceId     String
  type            String   // 'plan_grant', 'topup', 'consume', 'refund', 'expire'
  amount          Int      // positive for topup/grant, negative for consume/expire
  metadata        Json?    // For tracking Razorpay orderId or generation metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  @@index([workspaceId, type, createdAt])
}
